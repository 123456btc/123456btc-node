# ═══════════════════════════════════════════════════════════
# 123456btc-node Production Environment Template
# Copy to .env and fill in real values before deployment
# ═══════════════════════════════════════════════════════════

# ── Node Environment ──
NODE_ENV=production
BBT_LOG_LEVEL=info

# ── Node Identity ──
# Provider ID — usually your Solana wallet address (required)
BBT_PROVIDER_ID=
# Provider name for display
BBT_NODE_NAME=My 123456btc Node
# Solana wallet address (this is your on-chain identity, required)
BBT_WALLET_ADDRESS=
# Platform treasury wallet (defaults to BBT_WALLET_ADDRESS if empty)
BBT_TREASURY_WALLET=

# ── Network ──
# HTTP/WebSocket port
BBT_NODE_PORT=1119
# Solana RPC endpoint
# Mainnet: https://api.mainnet-beta.solana.com
# Devnet:  https://api.devnet.solana.com
# Custom:  https://your-rpc.example.com
BBT_SOLANA_RPC=https://api.mainnet-beta.solana.com

# ── BBT Token ──
# BBT token mint address on Solana
BBT_BBT_MINT=3s4AK2x2nGkKP8ZADbcKuhdPr3coSuh1XnwZEzWgpump

# ── Settlement ──
# Settlement mode: memo (simple) | escrow (on-chain escrow contract)
BBT_SETTLEMENT_MODE=memo

# ── Security ──
# Admin API key for /admin/* endpoints (auto-generated on init, set manually for production)
BBT_ADMIN_API_KEY=
# Provider secret (optional, legacy compatibility)
BBT_PROVIDER_SECRET=

# ── P2P Network ──
# Comma-separated seed peer WebSocket URLs
BBT_SEEDS=

# ── Telegram Bot (optional) ──
TELEGRAM_BOT_TOKEN=

# ── Auto Execution (optional) ──
# Set to 'true' to enable automatic trade execution via Jupiter
ENABLE_AUTO_EXECUTION=false

# ── IPFS / Arweave (optional, for backup) ──
ARWEAVE_GATEWAY=https://arweave.net

# ── Rate Limiting ──
# Max requests per minute per IP (default: 100)
RATE_LIMIT_MAX=100

# ── Logging ──
# Log persistence in days (default: 7)
BBT_LOG_PERSIST_DAYS=7
